# =================================
# 🔧 SKYEXPERIENCE BACKEND CONFIG
# =================================

# ==================
# 📊 DATABASE
# ==================
# MongoDB Atlas Connection String
# Get it from: https://cloud.mongodb.com
DATABASE_URL="mongodb+srv://skyExperience:skyExperience@skyexperience.m7wjwfk.mongodb.net/skyexp?appName=SkyExperience"

# ==================
# 🌐 SERVER CONFIG
# ==================
# Port for the backend server
PORT=5000

# Node Environment (development/production)
NODE_ENV=development

# Frontend URL(s) for CORS (comma-separated for multiple origins)
# Local: http://localhost:3000
# Production: https://your-frontend.vercel.app
ORIGIN=http://localhost:3000

# ==================
# 🔐 SECURITY
# ==================
# JWT Secret Key (CHANGE THIS IN PRODUCTION!)
# Generate strong key: openssl rand -base64 32
JWT_KEY=change_this_to_secure_random_string_in_production_123456789

# ==================
# 📧 EMAIL CONFIG
# ==================
# For Gmail: Use App Password (not regular password)
# Enable 2FA: https://myaccount.google.com/security
# Generate App Password: https://myaccount.google.com/apppasswords
MAIL_USER=youremail@gmail.com
MAIL_PASS=your-16-character-app-password

# SMTP Settings (optional - defaults to Gmail)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587

# ==================
# ☁️ CLOUDINARY (Image Upload)
# ==================
# Get credentials from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ==================
# 📝 NOTES
# ==================
# 1. Copy this file to .env: cp env.example .env
# 2. Fill in all values with your actual credentials
# 3. NEVER commit .env to Git (already in .gitignore)
# 4. For Render deployment, add these as Environment Variables

